[Unit]
Description=Sysguage Arduino USB serial driver
Documentation=https://github.com/SuhJae/sys-guage
After=multi-user.target

[Service]
Type=simple
User=@SYS_GUAGE_USER@
Group=dialout
SupplementaryGroups=dialout
ExecStart=/usr/local/bin/sysguage
Restart=always
RestartSec=10
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadOnlyPaths=/proc

[Install]
WantedBy=multi-user.target
